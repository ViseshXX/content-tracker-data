{
  "config_version": 1,
  "input_paths": {
    "content_dir": "/path/to/your/csv-downloads/content",
    "collection_file": "/path/to/your/csv-downloads/Collection.csv",
    "multilingual_file": "/path/to/your/csv-downloads/Multilingual.csv"
  },
  "safety": {
    "deletion_threshold_percent": 10,
    "deletion_threshold_min": 50
  },
  "collections": {
    "content": {
      "file_pattern": "data/content/{language}/content.ndjson",
      "identity_field": "_id",
      "language_partitioned": true,
      "ignore_for_diff": [
        "__v",
        "updatedAt"
      ],
      "edn_fields": [
        "contentSourceData",
        "mechanics_data",
        "multilingual",
        "level_complexity",
        "tags"
      ],
      "header_map": {
        "ID": "_id",
        "_id": "_id",
        "ContentId": "contentId",
        "CollectionId": "collectionId",
        "Name": "name",
        "ContentType": "contentType",
        "ImagePath": "imagePath",
        "ContentSourceData": "contentSourceData",
        "Status": "status",
        "Publisher": "publisher",
        "Language": "language",
        "ContentIndex": "contentIndex",
        "Tags": "tags",
        "CreatedAt": "createdAt",
        "UpdatedAt": "updatedAt",
        "V": "__v",
        "Mechanics Data": "mechanics_data",
        "Level Complexity": "level_complexity",
        "Author": "author",
        "Category": "category",
        "Description": "description",
        "Multilingual": "multilingual"
      }
    },
    "collection": {
      "file_pattern": "data/collection/collection.ndjson",
      "identity_field": "_id",
      "language_partitioned": false,
      "ignore_for_diff": [
        "__v",
        "updatedAt"
      ],
      "edn_fields": [
        "level_complexity",
        "tags",
        "categories",
        "content_tags"
      ],
      "header_map": {
        "ID": "_id",
        "CollectionId": "collectionId",
        "Name": "name",
        "Description": "description",
        "Category": "category",
        "Author": "author",
        "Publisher": "publisher",
        "Edition": "edition",
        "ImagePath": "imagePath",
        "Language": "language",
        "DifficultyLevel": "difficultyLevel",
        "Status": "status",
        "AgeGroup": "ageGroup",
        "FlaggedBy": "flaggedBy",
        "LastFlaggedOn": "lastFlaggedOn",
        "FlagReasons": "flagReasons",
        "Reviewer": "reviewer",
        "ReviewStatus": "reviewStatus",
        "Level Complexity": "level_complexity",
        "Tags": "tags",
        "CreatedAt": "createdAt",
        "UpdatedAt": "updatedAt",
        "V": "__v",
        "Categories": "categories",
        "Content Tags": "content_tags",
        "ParagraphCount": "paragraphCount",
        "Reading Level": "reading_level",
        "Synopsis": "synopsis",
        "Title": "title",
        "Type Of Learner": "type_of_learner"
      }
    },
    "multilingual": {
      "file_pattern": "data/multilingual/multilingual.ndjson",
      "identity_field": "_id",
      "language_partitioned": false,
      "ignore_for_diff": [
        "__v",
        "updatedAt"
      ],
      "edn_fields": [
        "multilingual"
      ],
      "header_map": {
        "ID": "_id",
        "Multilingual ID": "multilingual_id",
        "Multilingual": "multilingual",
        "CreatedAt": "createdAt",
        "UpdatedAt": "updatedAt",
        "V": "__v"
      }
    }
  }
}